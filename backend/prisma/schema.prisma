model branch {
  id           String         @id
  name         String
  tenantId     String
  tenant       tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  userbranch   userbranch[]

  @@index([tenantId], map: "Branch_tenantId_fkey")
}

model userbranch {
  id       String @id
  userId   String
  branchId String
  branch   branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user     user   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId], map: "UserBranch_userId_branchId_key")
  @@index([branchId], map: "UserBranch_branchId_fkey")
  @@index([userId], map: "UserBranch_userId_fkey")
}

model userpermission {
  id           String     @id
  userId       String
  permissionId String
  permission   permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         user       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId], map: "UserPermission_userId_permissionId_key")
  @@index([permissionId], map: "UserPermission_permissionId_fkey")
  @@index([userId], map: "UserPermission_userId_fkey")
}
